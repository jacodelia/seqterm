# Maintainer: Jorge Codelia <jorgecodelia@gmail.com>
pkgname=seqterm
pkgver=0.1.0
pkgrel=1
pkgdesc="Terminal-based modular sequencer / DAW"
arch=('x86_64' 'aarch64')
url="https://github.com/jacodelia/seqterm"
license=('MIT')
depends=('alsa-lib' 'pipewire' 'pipewire-alsa')
optdepends=(
    'fluidsynth: high-quality SF2 synthesis via FluidSynth backend'
    'jack2: JACK audio backend support'
)
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/jacodelia/seqterm/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    cargo build --release --locked
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "target/release/seqterm" "$pkgdir/usr/bin/seqterm"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    if [ -f "seqterm.1" ]; then
        install -Dm644 "seqterm.1" "$pkgdir/usr/share/man/man1/seqterm.1"
    fi
    if [ -d "docs" ]; then
        install -dm755 "$pkgdir/usr/share/doc/$pkgname"
        cp -r docs/* "$pkgdir/usr/share/doc/$pkgname/"
    fi
}
